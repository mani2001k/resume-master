{
  "name": "node-pdfplumber",
  "version": "1.0.0",
  "description": "PDF text, table and data extraction for Node.js — pdfplumber API for Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "dev": "tsup src/index.ts --watch --outDir dist"
  },
  "dependencies": {
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "pdf-lib": "^1.17.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "pdf",
    "parse",
    "extract",
    "table",
    "pdfplumber",
    "text-extraction"
  ],
  "license": "MIT",
  "author": "devslane",
  "repository": {
    "type": "git",
    "url": "https://github.com/devslane/node-pdfplumber"
  },
  "bugs": {
    "url": "https://github.com/devslane/node-pdfplumber/issues"
  },
  "homepage": "https://github.com/devslane/node-pdfplumber#readme"
}
